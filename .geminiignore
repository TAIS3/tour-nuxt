# ==========================================
# 敏感信息与凭据 (核心保护)
# ==========================================
.env
.env.*
*.pem
*.key
*.pub
*.p12
*.cert
secrets.py
credentials.json
# 排除 FastAdmin 的数据库配置文件
application/database.php
application/config.php

# ==========================================
# 量化交易敏感文件 (重要)
# ==========================================
# 包含 A 股或交易所 API Key 的文件
config/trade_keys.json
*auth_config*
# 排除历史交易数据（文件太大，没必要让 AI 读取，浪费 Token）
data/*.csv
data/*.h5
data/*.db
logs/trading/

# ==========================================
# 服务器与运维敏感文件
# ==========================================
# 如果你在项目中存放了 Nginx 证书或 SSH 配置
nginx/certs/
scripts/deploy_keys/
known_hosts
inventory.ini

# ==========================================
# 依赖包与构建产物 (减少干扰，提升 AI 性能)
# ==========================================
node_modules/
vendor/
.nuxt/
.output/
dist/
build/
__pycache__/
*.pyc
.venv/
venv/

# ==========================================
# 本地缓存与日志
# ==========================================
.DS_Store
Thumbs.db
*.log
logs/
runtime/
.idea/
.vscode/
# 排除 Gemini 自身的临时数据
.gemini/

# ==========================================
# 大型媒体文件 (避免 Agent 尝试读取非文本文件)
# ==========================================
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.mp4
*.pdf